# Claude API (already required by the existing pipeline)
ANTHROPIC_API_KEY=

# Flask session secret, needed for OAuth state/flash messaging
FLASK_SECRET_KEY=

# Pinterest API v5 (developer app: https://developers.pinterest.com/apps/)
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:5000/auth/pinterest/callback

# Google Cloud OAuth client, Photos Picker API scope (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Spotify Web API (developer app: https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/spotify/callback
